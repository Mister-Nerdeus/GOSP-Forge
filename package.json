{
  "name": "gosp-forge",
  "version": "0.1.0",
  "private": true,
  "description": "Truth-first foundation workspace for GOSP Forge. Current implementation is a foundation skeleton, not a working product.",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "eslint .",
    "validate:examples": "pnpm --filter @gosp/cli start validate examples/projects/automated-water-filter.project-v2.json",
    "simulate:clean-water": "pnpm --filter @gosp/cli start simulate examples/projects/automated-water-filter.project-v2.json",
    "estimate:clean-water": "pnpm --filter @gosp/cli start estimate examples/projects/automated-water-filter.project-v2.json",
    "audit": "pnpm --filter @gosp/cli start audit foundation"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.6.2",
    "eslint": "^9.39.1",
    "globals": "^15.15.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.2.0",
    "vitest": "^4.1.5"
  },
  "type": "module"
}
