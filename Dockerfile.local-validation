FROM node:24-bookworm-slim
WORKDIR /workspace
COPY . .
RUN corepack enable && corepack prepare pnpm@9.15.5 --activate
RUN pnpm install --frozen-lockfile=false
RUN node scripts/controls/verify-runtime-version.mjs && pnpm lint && pnpm -r build && pnpm -r typecheck && pnpm -r test
CMD ["node", "scripts/controls/write-local-validation.mjs"]
